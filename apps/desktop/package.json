{
  "name": "@continental/sovereign-desktop",
  "version": "0.1.1",
  "private": true,
  "productName": "Sovereign",
  "description": "Sovereign is a transparent desktop system control center for Windows 11.",
  "author": "Continental",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "package:win": "npm run build && set \"ELECTRON_CACHE=..\\..\\.electron-cache\" && set \"ELECTRON_BUILDER_CACHE=..\\..\\.electron-builder-cache\" && electron-builder --win nsis --x64"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sql.js": "^1.14.1",
    "systeminformation": "^5.31.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.continental.sovereign",
    "electronVersion": "30.0.0",
    "productName": "Sovereign",
    "copyright": "Copyright © 2026 Continental",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-Setup-${arch}.${ext}"
    }
  }
}
